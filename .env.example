# Sentinel — Docker Compose configuration.
# Copy to `.env` (compose auto-loads it) and fill in the two REQUIRED secrets.
#
#   cp .env.example .env
#
# This file configures the whole-stack compose deploy. The backend's own
# backend/.env.example is for running the API directly with `just run`.

# --- REQUIRED for any networked deployment ----------------------------------
# API auth gate (S9a). EMPTY = gate OPEN, i.e. every request is accepted —
# acceptable ONLY on a trusted localhost. NEVER expose the stack to a network
# with this unset. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=

# Fernet key ring encrypting secrets at rest (auth-source credentials, alert
# channel configs). Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotate by PREPENDING a new key (all keys decrypt, the first encrypts):
#   SECRET_KEY=<new-key>,<old-key>
SECRET_KEY=

# --- Database ----------------------------------------------------------------
# Password for the bundled Postgres (both the role and database are "sentinel").
# Change it for anything beyond a local trial.
POSTGRES_PASSWORD=sentinel

# --- Optional ----------------------------------------------------------------
# Host port the SPA (nginx "frontend" service) is published on — the app's entry
# point: http://localhost:${FRONTEND_PORT}.
FRONTEND_PORT=8080

# Host port the API ("web" service) is published on directly. The SPA reaches
# the API through nginx on FRONTEND_PORT; this is for debugging/direct access.
WEB_PORT=8000

# Block outbound probes to loopback/link-local/private/metadata addresses.
# Disable ONLY for trusted single-host setups that must monitor private targets.
SSRF_GUARD_ENABLED=true

# Base URL of the dashboard, used to build alert deep links (no trailing slash).
# For the compose stack this is the frontend, e.g. http://localhost:8080.
DASHBOARD_BASE_URL=

# Dead-man's-switch URL pinged each scheduler cycle (e.g. healthchecks.io).
HEARTBEAT_URL=
