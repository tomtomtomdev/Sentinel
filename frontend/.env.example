# Sentinel frontend — Vite env (all values are PUBLIC: they are baked into the
# static bundle at build time; never put a real production secret here).

# Base URL of the Sentinel API. Default "/api/v1" assumes same-origin serving
# (or the dev proxy in vite.config.ts forwarding /api to localhost:8000).
VITE_API_BASE_URL=/api/v1

# Dev-convenience fallback for the S9a Bearer token. In a deployed build,
# leave this UNSET and enter the token in the UI instead (stored in
# localStorage) — anything set here is readable by anyone with the JS bundle.
VITE_AUTH_TOKEN=
