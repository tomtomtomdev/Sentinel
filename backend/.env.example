# Sentinel backend configuration (12-factor; see PLAN §6).
# Copy to `.env` and fill in. NEVER commit a real `.env` or real keys.

# --- Database ---------------------------------------------------------------
# Async SQLAlchemy URL (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://localhost/sentinel

# --- Secret encryption at rest (SPEC §6) ------------------------------------
# Comma-separated Fernet key ring. The FIRST key encrypts; ALL keys decrypt, so
# rotating is: prepend a fresh key, redeploy, then drop the old key once nothing
# depends on it (MultiFernet — no re-encryption needed).
#
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# The value below is an EXAMPLE — generate your own; do not use it anywhere real.
SECRET_KEY=0o6-FRUa7N13wFoYxkelZhUTqEUSEinDMCYX6-5Vlp4=
# Rotation example (new key first, old key kept so existing ciphertext decrypts):
# SECRET_KEY=<new-key>,<old-key>

# --- API auth gate (S9a; SPEC §6) --------------------------------------------
# Static API credential: every /api/v1 route except /health requires
# `Authorization: Bearer <AUTH_TOKEN>`. Empty DISABLES the gate — acceptable only
# for local development; NEVER expose the API to a network without a token set.
#
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=

# --- SSRF guard (S10; SPEC §6) ------------------------------------------------
# Every outbound user-supplied URL (monitor probes, auth-source logins, webhook
# channels) is resolve-then-validated: loopback, link-local (incl. the cloud
# metadata IP 169.254.169.254), private, unspecified, and multicast ranges are
# refused. Keep ON. Disable only for trusted single-host self-hosting where
# monitors legitimately target private addresses.
SSRF_GUARD_ENABLED=true

# --- Alerting (SPEC §3.7) ---------------------------------------------------
# System-wide notify policy for the pure `should_notify` decision.
# Flap damping: >= ALERT_FLAP_THRESHOLD confirmed transitions within
# ALERT_FLAP_WINDOW_SECONDS send a single "flapping" summary and suppress further
# per-transition alerts until it stabilizes. A threshold < 2 disables damping.
ALERT_FLAP_THRESHOLD=5
ALERT_FLAP_WINDOW_SECONDS=600
# Re-notify cooldown (seconds): rate-limit a repeat alert for the same status.
# 0 (default) = one alert per confirmed transition.
ALERT_RENOTIFY_AFTER_SECONDS=0
# Base URL of the dashboard, used to build the deep link in an alert. Empty omits
# the link. No trailing slash needed.
DASHBOARD_BASE_URL=
