# Sentinel backend configuration (12-factor; see PLAN §6).
# Copy to `.env` and fill in. NEVER commit a real `.env` or real keys.

# --- Database ---------------------------------------------------------------
# Async SQLAlchemy URL (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://localhost/sentinel

# --- Secret encryption at rest (SPEC §6) ------------------------------------
# Comma-separated Fernet key ring. The FIRST key encrypts; ALL keys decrypt, so
# rotating is: prepend a fresh key, redeploy, then drop the old key once nothing
# depends on it (MultiFernet — no re-encryption needed).
#
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# The value below is an EXAMPLE — generate your own; do not use it anywhere real.
SECRET_KEY=0o6-FRUa7N13wFoYxkelZhUTqEUSEinDMCYX6-5Vlp4=
# Rotation example (new key first, old key kept so existing ciphertext decrypts):
# SECRET_KEY=<new-key>,<old-key>
